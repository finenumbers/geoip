# Database (local dev — direct Postgres; Docker Compose uses pgbouncer via compose overrides)
DATABASE_URL=postgresql://geoip:geoip@localhost:5433/geoip
DATABASE_DIRECT_URL=postgresql://geoip:geoip@localhost:5433/geoip
DATABASE_POOL_MAX=20
STATEMENT_TIMEOUT_MS=30000

# GRChC LK credentials (never commit real values)
GEOIP_LK_EMAIL=
GEOIP_LK_PASSWORD=

# Import
IMPORT_API_KEY=change-me-in-production
# Optional separate key for API auth (defaults to IMPORT_API_KEY)
# API_KEY=
# Protect Dashboard ops endpoints (/metrics, /dataset/active, /imports) in production
API_AUTH_ENABLED=false

# Export worker
EXPORT_POLL_INTERVAL_MS=5000
EXPORT_RETENTION_DAYS=7
EXPORT_RETENTION_LIMIT=100
# Daily dataset import at 20:00 Europe/Moscow (minute hour * * *)
IMPORT_CRON_CRON=0 20 * * *
IMPORT_CRON_TZ=Europe/Moscow
IMPORT_DOWNLOAD_DIR=/tmp/geoip-import
IMPORT_ZIP_CACHE_ENABLED=true
IMPORT_SKIP_UNCHANGED_DATASET=false
IMPORT_STAGING_SNAPSHOT_ENABLED=true
IMPORT_POLL_INTERVAL_MS=5000
IMPORT_STALE_MINUTES=20

# ASN mapping (import pipeline)
ASN_MAP_BATCH_SIZE=50000
ASN_MAP_WORKERS=6

# API
API_PORT=3000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

# Web (dev proxy target)
VITE_API_URL=http://localhost:3000

# Google Maps Embed API (IP Lookup map; restrict key by HTTP referrer in Google Cloud)
VITE_GOOGLE_MAPS_API_KEY=
