# Только для локальной разработки вне Docker (npm run dev, psql на localhost).
# Docker Compose использует defaults из docker-compose.yml — этот файл не обязателен.

DATABASE_URL=postgresql://geoip:geoip@localhost:5433/geoip
DATABASE_DIRECT_URL=postgresql://geoip:geoip@localhost:5433/geoip

# Runtime config store (создаётся автоматически при первом запуске API)
CONFIG_DATA_DIR=./data/config
# CONFIG_MASTER_KEY=  # опционально: 64 hex-символа для стабильного шифрования secrets.enc

# Dev
NODE_ENV=development
VITE_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
