# Portainer Stack → Environment variables
# Скопируйте каждую строку в Stacks → geoip → Environment variables.
#
# Compose path в Portainer: docker-compose.portainer.yml
# Подробная инструкция: docs/PORTAINER.md

POSTGRES_USER=geoip
POSTGRES_PASSWORD=замените-на-сильный-пароль

POSTGRES_DB=geoip

CONFIG_MASTER_KEY=

BACKUP_INTERVAL_SECONDS=86400

GEOIP_IMAGE_TAG=latest
