# Portainer Stack → Environment variables
# Скопируйте каждую строку в Stacks → geoip → Environment variables.
# Файл .env на сервере НЕ нужен.
#
# Подробная инструкция: docs/PORTAINER.md

POSTGRES_USER=geoip
POSTGRES_PASSWORD=замените-на-сильный-пароль

POSTGRES_DB=geoip

# 64 hex-символа: openssl rand -hex 32
# Сохраните backup — без ключа secrets.enc не расшифровать.
CONFIG_MASTER_KEY=

# Интервал автобэкапа Postgres (секунды). 86400 = раз в сутки.
BACKUP_INTERVAL_SECONDS=86400

# ОБЯЗАТЕЛЬНО для Portainer — готовые образы GHCR, без локальной сборки
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml:infra/portainer/docker-compose.images.yml

# Тег образов (latest или SHA коммита из GitHub Actions)
GEOIP_IMAGE_TAG=latest
