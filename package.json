{
  "name": "geoip-analytics",
  "version": "0.1.0",
  "private": true,
  "description": "GeoIP Analytics — analytics and lookup for GRChC Russia GeoIP datasets",
  "author": "Finenumbers <apps@finenumbers.com>",
  "license": "MIT",
  "homepage": "https://github.com/finenumbers/geoip#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finenumbers/geoip.git"
  },
  "bugs": {
    "url": "https://github.com/finenumbers/geoip/issues",
    "email": "apps@finenumbers.com"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @geoip/api --filter @geoip/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @geoip/api db:migrate",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "knip": "knip --include files,dependencies"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "knip": "6"
  }
}
